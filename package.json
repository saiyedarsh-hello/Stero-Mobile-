{
  "name": "stero",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev:react": "vite",
    "dev:electron": "electron electron/main.cjs",
    "dev": "concurrently -k \"npm run dev:react\" \"npm run dev:electron\"",
    "build:react": "vite build",
    "build:electron": "tsup",
    "build": "npm run build:react && npm run build:electron",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.40.0",
    "music-metadata": "^11.12.3",
    "node-youtube-music": "^0.10.3",
    "react-virtuoso": "^4.18.7",
    "youtube-dl-exec": "^3.1.7",
    "youtube-ext": "^1.1.25",
    "youtube-music-api": "^1.0.6",
    "yt-search": "^2.13.1",
    "ytmusic-api": "^5.3.1",
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "javascript-obfuscator": "^5.4.3",
    "jimp": "^1.6.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "vite": "^8.0.12",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.stero.musicplayer",
    "productName": "Stero",
    "npmRebuild": false,
    "asar": false,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stero"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!**/node_modules/@biomejs/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/youtube-dl-exec/bin/**/*",
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "output": "dist-desktop"
    }
  }
}
